# ═══════════════════════════════════════════════
# Construction AI Core — Environment Variables
# ═══════════════════════════════════════════════
# Скопируйте этот файл в .env и заполните значения

# ── LLM Providers ──────────────────────────────
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic (Claude): https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# GigaChat (Сбер): OAuth credentials в формате base64(client_id:client_secret)
# Получить в кабинете GigaChat API: https://developers.sber.ru/
GIGACHAT_CREDENTIALS=

# YandexGPT: API key из Yandex Cloud (IAM/API Keys)
# https://cloud.yandex.ru/docs/foundation-models/quickstart/yandexgpt
YANDEXGPT_API_KEY=

# DeepSeek: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# Groq: https://console.groq.com/keys
GROQ_API_KEY=

# Perplexity: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# ── Провайдер по умолчанию ─────────────────────
# perplexity | openai | claude | deepseek | groq
DEFAULT_LLM_PROVIDER=perplexity

# ── FastAPI ────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true
LOG_LEVEL=INFO
API_KEYS=["key1","key2"]
CORS_ORIGINS=tauri://localhost,http://localhost:1420,https://vanekpetrov1997.fvds.ru

# ── База данных ────────────────────────────────
DATABASE_URL=sqlite:///./data/construction_ai.db

# ── ChromaDB ───────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma

# ── Redis (только для серверного деплоя) ───────
# REDIS_URL=redis://localhost:6379/0

# ── Telegram Bot ───────────────────────────────
BOT_TOKEN=
TELEGRAM_ADMIN_IDS=
CORE_API_URL=http://api:8000
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=

# ── tk-generator (Node.js) ─────────────────────
TK_GENERATOR_PATH=../tk-generator

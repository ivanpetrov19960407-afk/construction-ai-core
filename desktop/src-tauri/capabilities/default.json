{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "store:default",
    "shell:allow-open",
    "fs:allow-read-dir",
    "core:path:default",
    "dialog:allow-message",
    "dialog:allow-ask",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://vanekpetrov1997.fvds.ru/*" },
        { "url": "http://vanekpetrov1997.fvds.ru/*" },
        { "url": "https://*.fvds.ru/*" }
      ]
    },
    "allow-get-api-url",
    "allow-set-api-url",
    "allow-pick-pdf-file",
    "allow-read-pdf-file-bytes",
    "allow-open-logs-folder",
    "allow-copy-last-log-lines",
    "allow-get-app-version"
  ]
}

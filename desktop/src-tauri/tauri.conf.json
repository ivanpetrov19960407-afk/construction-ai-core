{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Construction AI",
  "version": "0.2.0",
  "identifier": "ru.construction-ai.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Construction AI — ИИ-помощник",
        "width": 1200,
        "height": 780,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "opener": {},
    "fs": {},
    "dialog": {},
    "clipboard-manager": {}
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "msi", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
